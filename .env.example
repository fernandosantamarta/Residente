REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=

# Turns ON real money: card/ACH payments, saved methods, autopay, AND the daily
# charge-autopay / charge-plan-installment collection crons doing anything visible.
# lib/supabase reads NEXT_PUBLIC_STRIPE_ENABLED first, then REACT_APP_STRIPE_ENABLED.
# NEXT_PUBLIC_* is inlined at BUILD time, so after setting it on the host (Vercel
# project settings) you must REDEPLOY. Set to "true" only after the Stripe edge
# functions are deployed (supabase/README.md). Until then the Pay button stays disabled.
NEXT_PUBLIC_STRIPE_ENABLED=
REACT_APP_STRIPE_ENABLED=

# Rollout switch for the paid Accounting workspace (/admin/accounting): general
# ledger, bank reconciliation, bank-verified statements. When unset/"false" the
# workspace renders an upsell + demo preview instead of the live data.
NEXT_PUBLIC_ACCOUNTING_ENABLED=
